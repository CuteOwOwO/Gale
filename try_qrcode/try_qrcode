import qrcode

def generate_qr_code(image_url, output_filename="demo_qrcode.png"):
    # 建立 QR Code 物件，設定大小和容錯率
    qr = qrcode.QRCode(
        version=1,
        error_correction=qrcode.constants.ERROR_CORRECT_L,
        box_size=10,
        border=4,
    )
    
    # 將圖片的網址放入 QR Code 中
    qr.add_data(image_url)
    qr.make(fit=True)

    # 產生 QR Code 圖片 (可以自訂顏色)
    img = qr.make_image(fill_color="black", back_color="white")
    
    # 存檔
    img.save(output_filename)
    print(f"✅ QR Code 已成功產生並存為 {output_filename}")
    print(f"📱 掃描後會連到: {image_url}")

# 測試：我們先拿一張網路上隨便的柴犬狗狗圖當作「早安圖」的網址
dummy_image_url = "https://images.dog.ceo/breeds/shiba/shiba-14.jpg"

if __name__ == "__main__":
    generate_qr_code(dummy_image_url)